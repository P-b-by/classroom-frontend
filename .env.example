# Copy to .env and set secure values in production
# Admin password used to seed server (do NOT commit real secrets)
ADMIN_PASSWORD=kadot@admin

# Session secret for express-session
SESSION_SECRET=replace_with_a_random_secure_value

# When behind a proxy set to 1 to enable trust proxy for secure cookies
TRUST_PROXY=1

# NODE_ENV=production
# PORT=4000

# Optional local dev API base URL when the frontend is served separately.
# When the app is deployed from the same host, leave this blank or omit it.
VITE_API_URL=http://localhost:4000

# For Vercel frontend deployment, set this to your backend URL:
# VITE_API_URL=https://your-backend.example.com

# Backend CORS for separate frontend hosting.
# Use a comma-separated list if you need multiple allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# For Vercel, use your frontend URL and set cookie policy to none.
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
COOKIE_SAME_SITE=none
