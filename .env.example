# Copy to .env and set secure values in production
# Admin password used to seed server (do NOT commit real secrets)
ADMIN_PASSWORD=kadot@admin

# Session secret for express-session
SESSION_SECRET=replace_with_a_random_secure_value

# When behind a proxy set to 1 to enable trust proxy for secure cookies
TRUST_PROXY=1

# NODE_ENV=production
# PORT=4000

# Optional local dev API base URL when the frontend is served separately.
# When the app is deployed from the same host, leave this blank or omit it.
VITE_API_URL=http://localhost:4000

# For Vercel frontend deployment, set this to your backend URL:
# VITE_API_URL=https://your-backend.example.com

# Backend CORS for separate frontend hosting.
# Use a comma-separated list if you need multiple allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# For Vercel, use your frontend URL and set cookie policy to none.
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
COOKIE_SAME_SITE=none

# ============================================
# EMAIL CONFIGURATION GUIDE
# ============================================

# IMPORTANT: Choose ONE email provider and configure it properly

# ============================================
# OPTION 1: GMAIL (Development/Testing)
# ============================================
# Steps to setup Gmail:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to Google Account Settings → Security → 2-Step Verification
# 3. Select "App passwords" → "Select app" → "Other (Custom name)"
# 4. Enter a name like "Domas Ventures Orders" and generate password
# 5. Use the generated 16-character password (not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-actual-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# ============================================
# OPTION 2: SENDGRID (Production Recommended)
# ============================================
# Steps to setup SendGrid:
# 1. Create account at sendgrid.com (free tier available)
# 2. Go to Settings → API Keys → Create API Key
# 3. Choose "Restricted Access" with limited permissions
# 4. Copy your API Key (starts with SG.)
# 5. For production, upgrade to a dedicated IP for better deliverability
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=SG.YOUR_GENERATED_API_KEY_HERE

# ============================================
# OPTION 3: MAILGOOD (Business Email)
# ============================================
# Steps to setup Mailgun:
# 1. Create account at mailgun.com
# 2. Verify your domain (or use sandbox domain)
# 3. Go to Settings → Domains → Your Domain → SMTP Authentication
# 4. Create SMTP credentials
# 5. Use default or create custom SMTP username/password
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_USER=postmaster@your-domain.com
EMAIL_PASS=your-mailgun-smtp-password

# ============================================
# OPTION 4: AMAZON SES (Enterprise/High Volume)
# ============================================
# Steps to setup Amazon SES:
# 1. Create AWS account if you don't have one
# 2. Navigate to Amazon SES service
# 3. Verify your email addresses/domain
# 4. Create SMTP credentials in SMTP Settings
# 5. Use IAM user with limited permissions for security
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USER=your-aws-access-key-id
EMAIL_PASS=your-aws-secret-access-key

# ============================================
# OPTION 5: MAILJET (Business Email Alternative)
# ============================================
# Steps to setup Mailjet:
# 1. Create account at mailjet.com
# 2. Go to Account Settings → SMTP & Sending
# 3. Click on SMTP to view your credentials
# 4. Use the API Key and Secret Key for SMTP authentication
EMAIL_HOST=in-v3.mailjet.com
EMAIL_PORT=587
EMAIL_USER=your-mailjet-api-key
EMAIL_PASS=your-mailjet-secret-key

# ============================================
# OPTION 6: OUTLOOK/OFFICE 365 (Microsoft)
# ============================================
# Steps to setup Outlook:
# 1. Enable POP3/IMAP in Outlook web settings
# 2. Generate an "App Password" if using 2FA
# 3. Office 365: Use your organization's SMTP server settings
# 4. Personal Outlook: Account Settings → Security → App Passwords
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=your-email@outlook.com
EMAIL_PASS=your-app-password

# ============================================
# OPTION 7: YOUR OWN SMTP SERVER
# ============================================
# Configure with your organization's mail server:
# Usually your IT department provides these details
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=587
EMAIL_USER=your-email@yourdomain.com
EMAIL_PASS=your-smtp-password

# ============================================
# TROUBLESHOOTING EMAIL ISSUES
# ============================================

# Gmail Common Issues:
# - "Invalid login" → Enable 2FA and use App Password
# - "Connection refused" → Use port 587 (not 465) for TLS
# - "Self-signed certificate" → This is normal with Gmail on port 587

# Common Email Problems:
# - Emails going to Spam: Check SPF, DKIM, and DMARC records
# - Connection timeout: Check firewall allows port 587
# - Authentication failed: Verify username/password are correct
# - Rate limiting: Some providers limit sending rates

# Testing Email Setup:
# - Start with Gmail for development and testing
# - Use SendGrid or Mailgun for production applications
# - Consider transactional email services for reliability
# - Test with personal email before customer emails
